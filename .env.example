# --- Database (Postgres) ---
# Dev: docker compose up -d db  →  Postgres on localhost:55434
DATABASE_URL="postgresql://michelin:michelin@localhost:55434/michelin_plus?schema=public"

# --- Auth ---
# Secret used to sign the session cookie (HS256). Change in prod.
SESSION_SECRET="dev-michelin-plus-session-secret-change-me-please-32b"

# --- Debug panel ---
# Simple shared password gating /debug and /api/debug/* (demo control panel).
DEBUG_TOKEN="grip"

# --- App ---
NEXT_PUBLIC_APP_NAME="Michelin+"
